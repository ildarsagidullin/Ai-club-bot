# ========================================
# НАСТРОЙКИ БОТА AI CLUB NHA TRANG
# Скопируй этот файл в .env и заполни
# ========================================

# Токен бота — получить у @BotFather в Telegram
BOT_TOKEN=your_bot_token_here

# Твой Telegram ID (число, не username)
# Узнать свой ID: написать боту @userinfobot
ADMIN_ID=123456789

# Пароль для команды /admin (придумай сам)
ADMIN_PASSWORD=mypassword123

# Ссылка на сообщество (канал или чат — куда отправлять после регистрации)
COMMUNITY_LINK=https://t.me/your_community_here
